# Copy to .env and adjust. All values are optional; sensible defaults apply.
# The .env file is gitignored — never commit real secrets.

# Runtime data directory (cache, logs, settings, history).
DATA_DIR=data

# Freshness window, in seconds, before cached API data is refetched.
CACHE_TTL_SECONDS=300

# Approximate USD->Toman conversion rate (see ADR-005 / TD-04).
USD_TO_TOMAN_RATE=90000

# API Keys. Crypto works without a key; football degrades gracefully if unset.
CRYPTO_API_KEY=
FOOTBALL_API_KEY=
