# Copy to .env and adjust. All values are optional; sensible defaults apply.
# The .env file is gitignored — never commit real secrets.

# Runtime data directory (cache, logs, settings, history).
DATA_DIR=data

# Freshness window, in seconds, before cached API data is refetched.
CACHE_TTL_SECONDS=300

# Approximate USD->Toman conversion rate (see ADR-005 / TD-04).
USD_TO_TOMAN_RATE=170000

# API Keys. All sources work without a key on their free tiers.
# CRYPTO_API_KEY  -> Wallex (Toman prices). Public endpoints are free.
# COINGECKO_API_KEY -> CoinGecko Demo key (optional, raises rate limits).
CRYPTO_API_KEY=
COINGECKO_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BROADCAST_CHAT_ID=
